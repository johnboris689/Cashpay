generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id         String   @id @default(cuid())
  fullName   String
  email      String   @unique
  password   String
  role       String   @default("user")
  isVerified Boolean  @default(false)

  consent    Consent?
  wallet     Wallet?
}

model Consent {
  id         String  @id @default(cuid())
  userId     String  @unique
  accepted   Boolean
  acceptedAt DateTime?

  user User @relation(fields: [userId], references: [id])
}

model Wallet {
  id      String @id @default(cuid())
  userId  String @unique
  balance Int    @default(200000)

  user User @relation(fields: [userId], references: [id])
}

model Transaction {
  id        String @id @default(cuid())
  userId    String
  type      String
  amount    Int
  createdAt DateTime @default(now())
}
